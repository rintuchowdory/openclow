# HuggingFace API Configuration
# Get your free API key from: https://huggingface.co/settings/tokens
# This key is used server-side for the HuggingFace Inference API
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Public keys (visible to client-side code)
# HuggingFace public key (optional, for client-side usage)
NEXT_PUBLIC_HUGGINGFACE_API_KEY=your_public_huggingface_key_here

# Gemini API Configuration (fallback)
# Get your free API key from: https://ai.google.dev/
NEXT_PUBLIC_GEMINI_KEY=your_gemini_api_key_here

# OpenAI API Configuration (optional fallback)
OPENAI_API_KEY=your_openai_api_key_here
